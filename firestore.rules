rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email_verified == true && request.auth.token.email == 'tr-vlasova@mail.ru'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 && data.title.size() > 0 &&
             data.content is string && data.content.size() <= 50000 &&
             (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 1000) &&
             data.createdAt is timestamp &&
             (data.get('updatedAt', request.time) is timestamp);
    }
    
    function isValidPhoto(data) {
      return data.keys().hasAll(['imageUrl', 'createdAt']) &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 && data.imageUrl.size() > 0 &&
             (data.get('caption', '') is string && data.get('caption', '').size() <= 500) &&
             data.createdAt is timestamp;
    }

    match /articles/{articleId} {
      allow read: if true;
      
      allow create: if isAdmin() &&
                    isValidId(articleId) &&
                    isValidArticle(incoming()) &&
                    incoming().createdAt == request.time;
                    
      allow update: if isAdmin() &&
                    isValidId(articleId) &&
                    isValidArticle(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
                    
      allow delete: if isAdmin() && isValidId(articleId);
    }
    
    match /photos/{photoId} {
      allow read: if true;
      
      allow create: if isAdmin() &&
                    isValidId(photoId) &&
                    isValidPhoto(incoming()) &&
                    incoming().createdAt == request.time;
                    
      allow update: if isAdmin() &&
                    isValidId(photoId) &&
                    isValidPhoto(incoming()) &&
                    incoming().createdAt == existing().createdAt;
                    
      allow delete: if isAdmin() && isValidId(photoId);
    }
  }
}
